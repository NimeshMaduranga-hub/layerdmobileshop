      <ImageView layoutX="600.0" layoutY="287.0">
         <image>
            <Image url="@icon/Infinity.gif" />
         </image>
      </ImageView>
      <ImageView layoutX="589.0" layoutY="174.0">
         <image>
            <Image url="@icon/AI%20Tools.gif" />
         </image>
      </ImageView>
    </children>

</AnchorPane>
