<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.layerdmobileshop.mobileshop.controller.UserandPeopleController">

    <children>
      <ImageView fitHeight="644.0" fitWidth="800.0">
         <image>
            <Image url="@image/userandpeople.png" />
         </image>
      </ImageView>
      <Label fx:id="lblUser" layoutX="110.0" layoutY="70.0" prefHeight="20.0" prefWidth="126.0" />
      <Button fx:id="btnUserAndPeople" layoutY="172.0" mnemonicParsing="false" onAction="#btnUserAndPeopleOnAction" opacity="0.0" prefHeight="41.0" prefWidth="210.0" text="UserAndPeople" />
      <Button fx:id="btnOrdersAndItems" layoutY="232.0" mnemonicParsing="false" onAction="#btnOrdersAndItemsOnAction" opacity="0.15" prefHeight="41.0" prefWidth="210.0" />
      <Button fx:id="btnSuppliersGroup" layoutY="279.0" mnemonicParsing="false" onAction="#btnSuppliersGroupOnAction" opacity="0.15" prefHeight="41.0" prefWidth="210.0" />
