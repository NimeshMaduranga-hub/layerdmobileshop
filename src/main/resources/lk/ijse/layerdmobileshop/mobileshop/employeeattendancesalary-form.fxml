<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.layerdmobileshop.mobileshop.controller.AttendanceSalaryController">
   <ImageView fitHeight="600.0" fitWidth="861.0">
      <image>
         <Image url="@image/top-view-black-friday-sales-elements-composition.jpg" />
      </image>
   </ImageView>

    <!-- Back Button -->
    <Button fx:id="btnBack" layoutX="7.0" layoutY="10.0" onAction="#btnBackOnAction" prefHeight="22.0" prefWidth="77.0" style="-fx-background-color: #a9dbbc; -fx-text-fill: white;" text="Back" />

    <!-- Attendance + Salary Form -->
    <VBox layoutX="40.0" layoutY="50.0" prefHeight="240.0" prefWidth="746.0" spacing="10" style="-fx-background-color: #a9dbbc; -fx-padding: 10;">
        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1976d2;" text="Attendance" />
        <HBox spacing="10">
            <Label text="Date:" />
            <DatePicker fx:id="dpAttendanceDate" promptText="Attendance Date" />
        </HBox>
        <HBox spacing="10">
            <Label text="Check In:" />
            <TextField fx:id="txtCheckIn" promptText="HH:MM" />
            <Label text="Check Out:" />
            <TextField fx:id="txtCheckOut" promptText="HH:MM" />
            <Label text="Status:" />
            <ComboBox fx:id="cmbStatus" prefWidth="120" promptText="Select Status" />
        </HBox>

        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #43a047;" text="Salary Payment" />
        <HBox spacing="10">
            <Label text="Amount:" />
            <TextField fx:id="txtSalaryAmount" promptText="Salary Amount" />
            <Label text="Payment Date:" />
            <DatePicker fx:id="dpSalaryDate" promptText="Payment Date" />
        </HBox>

        <HBox prefHeight="22.0" prefWidth="223.0" spacing="10">
            <Button fx:id="btnSave" onAction="#btnSaveOnAction" style="-fx-background-color: #4cc7ce; -fx-text-fill: white;" text="Save" />
            <Button fx:id="btnClear" onAction="#btnClearOnAction" style="-fx-background-color: #f1e024;" text="Clear" />
        </HBox>
      <effect>
         <Blend />
      </effect>
    </VBox>

    <!-- Salary History Table -->
    <Label layoutX="22.0" layoutY="339.0" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #a9dbbc;" text="Salary History" />
    <TableView fx:id="tblSalaryHistory" layoutX="20.0" layoutY="373.0" prefHeight="199.0" prefWidth="360" style="-fx-background-color: #ffffff; -fx-border-color: #90caf9; -fx-border-width: 1;">
        <columns>
         <TableColumn fx:id="colEmpId" prefWidth="117.0" text="Employee ID" />
            <TableColumn fx:id="colSalaryDate" prefWidth="114.0" text="Date" />
            <TableColumn fx:id="colSalaryAmountHist" prefWidth="126.0" text="Amount" />
        </columns>
    </TableView>
    <!-- Optional: Employee Attendance History Table -->
    <Label layoutX="650.0" layoutY="339.0" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #a9dbbc;" text="Attendance History" />
    <ComboBox fx:id="cmbEmployee" layoutX="480.0" layoutY="19.0" prefWidth="300" promptText="Select Employee" />
    <TableView fx:id="tblAttendanceHistory" layoutX="387.0" layoutY="373.0" prefHeight="199.0" prefWidth="402.0" style="-fx-background-color: #ffffff; -fx-border-color: #90caf9; -fx-border-width: 1;">
        <columns>
            <TableColumn fx:id="colAttDate" prefWidth="100" text="Date" />
            <TableColumn fx:id="colCheckIn" prefWidth="113.0" text="Check In" />
            <TableColumn fx:id="colCheckOut" prefWidth="100.0" text="Check Out" />
            <TableColumn fx:id="colStatus" prefWidth="84.0" text="Status" />
        </columns>
    </TableView>
    <DatePicker fx:id="dpMonth" layoutX="590.0" layoutY="315.0" onAction="#filterByMonth" prefHeight="21.0" prefWidth="193.0" promptText="Select Month" />

</AnchorPane>
