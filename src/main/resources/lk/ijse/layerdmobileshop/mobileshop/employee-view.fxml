<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="644.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.layerdmobileshop.mobileshop.controller.EmployeeViewController">
   <children>
      <ImageView fitHeight="644.0" fitWidth="800.0">
         <image>
            <Image url="@image/ManageEmployeeUI.png" />
         </image>
      </ImageView>
      <TextField fx:id="txtEmployeeId" layoutX="231.0" layoutY="170.0" prefHeight="25.0" prefWidth="429.0" promptText="Employee ID :" />
      <TextField fx:id="txtEmployeeName" layoutX="231.0" layoutY="201.0" prefHeight="25.0" prefWidth="429.0" promptText="Employee Name :" />
      <TextField fx:id="txtEmployeeAddress" layoutX="231.0" layoutY="235.0" prefHeight="25.0" prefWidth="429.0" promptText="Employee Address :" />
      <TextField fx:id="txtEmployeeMobile" layoutX="231.0" layoutY="270.0" prefHeight="25.0" prefWidth="429.0" promptText="Employee Mobile :" />
      <TextField fx:id="txtEmployeeSalary" layoutX="408.0" layoutY="304.0" prefHeight="25.0" prefWidth="252.0" promptText="Employee Salary :" />
      <Button fx:id="btnAddEmployee" layoutX="684.0" layoutY="180.0" mnemonicParsing="false" onAction="#btnAddNew_OnAction" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #57442e;" text="+New Employee" textFill="WHITE" />
      <Button fx:id="btnSave" layoutX="370.0" layoutY="340.0" mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="25.0" prefWidth="70.0" style="-fx-background-color: #4cc7ce;" text="Save" />
      <Button fx:id="btnDelete" layoutX="450.0" layoutY="340.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="25.0" prefWidth="70.0" style="-fx-background-color: #f1e024;" text="Delete" />
      <TableView fx:id="tblEmployee" layoutX="214.0" layoutY="377.0" prefHeight="200.0" prefWidth="578.0">
        <columns>
            <TableColumn fx:id="colId" prefWidth="68.0" text="EMP ID" />
          <TableColumn fx:id="colName" prefWidth="120.0" text="Name" />
          <TableColumn fx:id="colAddress" prefWidth="123.0" text="Address" />
            <TableColumn fx:id="colMobile" prefWidth="96.0" text="Mobile" />
            <TableColumn fx:id="colSalary" prefWidth="90.0" text="Salary" />
            <TableColumn fx:id="colrole" text="Role" />
        </columns>
      </TableView>
      <Button fx:id="btnWorkLog" layoutX="649.0" layoutY="342.0" mnemonicParsing="false" onAction="#btnWorkLogOnAction" prefHeight="22.0" prefWidth="137.0" style="-fx-background-color: #3A7AFE;" text="Attendance &amp; Salary" textFill="WHITE" />
      <ComboBox fx:id="cmbRole" layoutX="230.0" layoutY="306.0" prefHeight="22.0" prefWidth="163.0" promptText="Select Role" />
       <Button fx:id="btnSuppliersGroup" layoutY="277.0" mnemonicParsing="false" onAction="#btnSuppliersGroupOnAction" opacity="0.15" prefHeight="45.0" prefWidth="211.0" />
       <Button fx:id="btnOrdersAndItems" layoutY="230.0" mnemonicParsing="false" onAction="#btnOrdersAndItemsOnAction" opacity="0.15" prefHeight="45.0" prefWidth="211.0" />
       <Button fx:id="btnWarrantyGroup" layoutY="324.0" mnemonicParsing="false" onAction="#btnWarrantyGroupOnAction" opacity="0.15" prefHeight="45.0" prefWidth="211.0" />
       <Button fx:id="btnLogout" layoutX="30.0" layoutY="555.0" mnemonicParsing="false" onAction="#handleLogout" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: FF3D1FFF;" text="Logout" textFill="WHITE" />
       <Button fx:id="btnManageCustomer" layoutX="608.0" layoutY="133.0" mnemonicParsing="false" onAction="#btnManageCustomerOnAction" opacity="0.15" prefHeight="25.0" prefWidth="188.0" />
      <Button fx:id="btnManageUser" layoutX="214.0" layoutY="133.0" mnemonicParsing="false" onAction="#btnManageUserOnAction" opacity="0.15" prefHeight="25.0" prefWidth="188.0" />

   </children>
</AnchorPane>
