         <image>
            <Image url="@icon/image-removebg-preview%20(25).png" />
         </image>
      </ImageView>
      <Text fill="#eedbdb" layoutX="488.0" layoutY="573.0" strokeType="OUTSIDE" strokeWidth="0.0" text="© 2026 All Rights Reserved | Developed by Nimesh Maduranga" />
