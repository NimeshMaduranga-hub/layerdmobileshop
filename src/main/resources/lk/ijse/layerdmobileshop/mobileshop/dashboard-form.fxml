      </ImageView>
      <Label fx:id="lblUser" layoutX="107.0" layoutY="66.0" prefHeight="17.0" prefWidth="125.0" text="Welcome!" />
      <ImageView fitHeight="778.0" fitWidth="1230.0" layoutX="211.0" layoutY="123.0">
